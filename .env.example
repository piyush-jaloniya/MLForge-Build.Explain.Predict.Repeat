# ── AI (optional — AI features degrade gracefully without this) ──────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_FLASH_MODEL=gemini-2.5-flash

# ── Security ──────────────────────────────────────────────────────────────
# REQUIRED in production — change this!
SECRET_KEY=change_me_before_deploying_to_production

# ── App ───────────────────────────────────────────────────────────────────
ENV=development                        # set to 'production' in prod
UPLOAD_MAX_MB=500
SESSION_TIMEOUT_HOURS=24
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Storage ───────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./mlforge.db
MLFLOW_TRACKING_URI=sqlite:///./mlruns.db
EXPERIMENTS_DIR=./experiments
SAMPLES_DIR=./data/samples
